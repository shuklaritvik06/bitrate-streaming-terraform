# Terraform working directory
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Terraform variable files (often contain secrets)
*.tfvars
*.tfvars.json

# Terraform plan files
*.tfplan
plan.out

# Crash logs
crash.log

# CLI configuration files
terraform.rc
.terraformrc

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform dependency lock file
.terraform.lock.hcl
